{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "go@latest",
    "gopls@latest",
    "golangci-lint@latest",
    "nodejs@24",
    "just@latest",
    "protobuf@latest"
  ],
  "shell": {
    "init_hook": [
      "if [ -f .env ]; then set -a; . ./.env; set +a; fi"
    ]
  }
}
